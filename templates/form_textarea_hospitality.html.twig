{% extends 'form_row.html.twig' %}

{% block label %}
    {% if this.label %}
        <label for="ctrl_{{ this.id }}" class="form-label">
            {% if this.mandatory|default %}
                <span class="invisible">{{ this.mandatoryField }} </span>{{ this.label|insert_tag_raw }}<span class="mandatory">*</span>
            {% else %}
                {{ this.label|insert_tag_raw }}
            {% endif %}
        </label>
    {% endif %}
{% endblock %}

{% block field %}
    {% if hasErrors.invoke() %}
        <p class="error">{{ getErrorAsString.invoke() }}</p>
    {% endif %}

    <textarea{{ attrs()
        .set('name', this.name)
        .set('id', "ctrl_#{this.id}")
        .addClass('form-input textarea')
        .set('rows', this.rows)
        .set('cols', this.cols)
        .mergeWith(getAttributes.invoke())
    }}>{{ this.value|insert_tag }}</textarea>
{% endblock %}
