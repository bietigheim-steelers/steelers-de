<!-- indexer::stop -->
<a href="{{ request }}#{{ skipId }}" class="sr-only">{{ skipNavigation }}</a>

{% set mobileToggleId = 'main-nav-toggle-' ~ (skipId|default('nav')) %}
{% set mobilePanelId = 'main-nav-panel-' ~ (skipId|default('nav')) %}

<style>
    @media (max-width: 1023.98px) {
        #{{ mobileToggleId }}:checked ~ #{{ mobilePanelId }} {
            opacity: 1;
            pointer-events: auto;
        }

        #{{ mobileToggleId }}:checked + label .line-1 {
            transform: translateY(7px) rotate(45deg);
        }

        #{{ mobileToggleId }}:checked + label .line-2 {
            opacity: 0;
        }

        #{{ mobileToggleId }}:checked + label .line-3 {
            transform: translateY(-7px) rotate(-45deg);
        }
    }
</style>

{# Mobile toggle without JavaScript #}
<input id="{{ mobileToggleId }}" type="checkbox" class="sr-only lg:hidden">

<label for="{{ mobileToggleId }}" class="fixed left-4 top-4 z-[130] inline-flex h-12 w-12 cursor-pointer items-center justify-center rounded-full border border-white/30 bg-steelnav/90 text-white backdrop-blur-sm shadow-lg lg:hidden" aria-controls="{{ mobilePanelId }}" aria-label="Menü öffnen">
    <span class="relative block h-4 w-6">
        <span class="line-1 absolute left-0 top-0 h-0.5 w-6 bg-current transition-transform duration-300"></span>
        <span class="line-2 absolute left-0 top-[7px] h-0.5 w-6 bg-current transition-opacity duration-300"></span>
        <span class="line-3 absolute left-0 top-[14px] h-0.5 w-6 bg-current transition-transform duration-300"></span>
    </span>
</label>

<div id="{{ mobilePanelId }}" class="pointer-events-none fixed inset-0 z-[120] bg-steelnav/95 opacity-0 transition-opacity duration-300 lg:static lg:z-auto lg:block lg:h-full lg:bg-transparent lg:opacity-100 lg:pointer-events-auto">
    <div class="flex min-h-screen flex-col items-center justify-center gap-2 px-4 py-16 text-white lg:min-h-0 lg:h-full lg:justify-center lg:gap-1 lg:overflow-y-auto lg:py-8">
        <a href="/" class="block w-32 max-w-[65%] lg:mb-2 lg:w-44" aria-label="Zur Startseite">
            {% include 'logo.html.twig' %}
        </a>

        <nav class="w-full" aria-label="Hauptnavigation">
            {{ items|raw }}
        </nav>

        {{ insert_tag('insert_article::after-nav-article')|raw }}
    </div>
</div>

<a id="{{ skipId }}" class="hidden">&nbsp;</a>
<!-- indexer::continue -->
