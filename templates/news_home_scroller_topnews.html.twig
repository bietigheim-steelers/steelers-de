{% use "@Contao/component/_figure.html.twig" %}
{% set game = game_id|get_game_details %}

<div class="swiper-slide bg-white h-full">
  <div class="slide-desc">
    <div class="swiper-slide__header"><a title="{{ newsHeadline }}" href="{{ link }}">
        <p class="swiper-slide__headline"><span itemprop="headline">{{ newsHeadline }}</span></p>
      </a></div>
    <p class="text-white text-xl hidden xl:block">
      {% if game %}
        {{ game.homeTeamDetails.name }} - {{ game.awayTeamDetails.name }}
      {% else %}
        {{  subHeadline }}
      {% endif %}
    </p>
    <div class="d-flex align-items-center read-more-wrap text-left"><a class="btn-default mt-4"
        title="{{ newsHeadline }}" href="{{ link }}">weiterlesen</a></div>
  </div>
  {% with {figure: singleSRC} %}
    {{ block('figure_component') }}
  {% endwith %}
</div>
