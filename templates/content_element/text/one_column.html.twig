{% use "@Contao/component/_picture.html.twig" %}
{% use "@Contao/component/_rich_text.html.twig" %}

{% if data.addImage %}
  {% set image = figure(
    data.singleSRC,
    [800, 800, 'crop'],
    { metadata: { alt: headline.text}, enableLightbox: true, linkHref: data.singleSRC })
  %}
{% endif %}

<div class="defaultcontainer px-0! my-6! {{ class|default }}">
  <div class="grid md:p-0 items-start gap-8">
    <div class="overflow-hidden border-t-4 border-gray-800">
      {% if data.addImage %}
        {% with {figure: image} %}
          {{ block('picture_component') }}
        {% endwith %}
      {% endif %}
    </div>
    <div class="flex flex-col items-start">
      <h4 class="text-2xl text-black font-sans uppercase font-bold mt-0!">
        {{ headline.text }}
      </h4>
      <div class="mt-2 leading-relaxed prose">
        {% with {text, attributes: text_attributes|default} %}
        {{ block('rich_text_component') }}
        {% endwith %}
        {% if data.url and data.linkTitle %}
          <p class="not-prose">
            <a href="{{ data.url }}" class="btn-default" {{ data.target == '1' ? 'target="_blank"' : '' }}>
              {{ data.linkTitle }}
            </a>
          </p>
        {% endif %}
      </div>
    </div>
  </div>
</div>
