{% use "@Contao/component/_figure.html.twig" %}

{% set background_image = picture_config({
    width: 768,
    height: 768,
    resizeMode: 'box'
}) %}
{% set image_size = picture_config({
    width: 400,
    height: 500,
    resizeMode: 'crop',
    sizes: '(max-width: 640px) 300px, 400px',
    densities: '1x, 2x'
}) %}

    <div class="relative overflow-hidden isolate">
      <div class="absolute -z-10 w-screen h-4/6 bg-black">
        {% if images[0] is defined %}
          <img src="{{ figure(images[0].image.img.src|add_root, background_image).image.img.src }}" class="w-full h-full object-center object-cover opacity-20 grayscale" alt="{{ headline.text }}"/>
        {% endif %}
      </div>
      <h3 class="pl-5">
        {{ headline.text }}
      </h3>
      <div class="swiper-gallery mx-2 md:mx-12" data-perrow="{{ items_per_row }}">
        <div class="swiper-wrapper" data-glide-el="track">
          {% for picture in images %}
            <li class="swiper-slide w-[300px] 2xl:w-[400px]">
              <a href="/{{ picture.image.img.src|add_root }}" class="glightbox" data-gallery="gallery{{ data.id }}">
                {% set image = figure(
                  picture.image.img.src|add_root,
                  image_size, 
                  {
                    metadata: { alt: headline.text },
                    options: { attr: { class: 'w-full h-full object-center object-cover' } }
                  })
                %}
                {% with {figure: image} %}
                  {{ block('figure_component') }}
                {% endwith %}
              </a>
            </li>
          {% endfor %}
        </div>
        <div class="mt-5 flex gap-14" data-glide-el="controls">
          <button class="swiper-button-left" aria-label="vorheriges Bild">
            <svg xmlns="http://www.w3.org/2000/svg" class="fill-black stroke-black" x="0px" y="0px" width="60px" height="40px" viewbox="0 0 60 40">
              <g>
                <line stroke-width="2" x1="62.5" y1="20.031" x2="20.5" y2="20.031"></line>
                <polygon stroke-miterlimit="10" points="21,25 15.406,20.093 21,15.06"></polygon>
                <path d="M19.938,2.045c9.866,0,17.893,8.026,17.893,17.893S29.804,37.83,19.938,37.83S2.045,29.804,2.045,19.938
                                S10.071,2.045,19.938,2.045 M19.938,0C8.926,0,0,8.926,0,19.938c0,11.011,8.926,19.938,19.938,19.938s19.938-8.927,19.938-19.938
                                C39.875,8.926,30.949,0,19.938,0L19.938,0z"></path>
              </g>
            </svg>
          </button>
          <button class="swiper-button-right" aria-label="nächstes Bild">
            <svg xmlns="http://www.w3.org/2000/svg" x="0px" y="0px" class="rotate-180 fill-black stroke-black" width="60px" height="40px" viewbox="0 0 60 40">
              <g>
                <line fill="none" stroke-width="2" x1="62.5" y1="20.031" x2="20.5" y2="20.031"></line>
                <polygon stroke-miterlimit="10" points="21,25 15.406,20.093 21,15.06"></polygon>
                <path d="M19.938,2.045c9.866,0,17.893,8.026,17.893,17.893S29.804,37.83,19.938,37.83S2.045,29.804,2.045,19.938
                                    S10.071,2.045,19.938,2.045 M19.938,0C8.926,0,0,8.926,0,19.938c0,11.011,8.926,19.938,19.938,19.938s19.938-8.927,19.938-19.938
                                    C39.875,8.926,30.949,0,19.938,0L19.938,0z"></path>
              </g>
            </svg>
          </button>
        </div>
      </div>
    </div>

