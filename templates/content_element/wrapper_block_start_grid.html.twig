<div class="defaultcontainer gridwrapper !px-2 md:px-0 block">
  <div>
    {% if headline is defined and headline.unit is defined and headline.value is defined %}
      <{{ headline.unit }} class="block-headline headline--small z-40 -mb-16 md:mb-0">
        {{ headline.value }}
      </{{ headline.unit }}>
    {% endif %} 
    <div class="inside grid {{ css | length > 15 ? css : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-16' }}">





