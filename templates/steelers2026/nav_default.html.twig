{% set isRoot = level == 'level_1' %}

<ul class="{{ level }} list-none m-0 p-0{% if isRoot %} flex flex-col items-center gap-y-0 text-center text-white{% else %} absolute left-1/2 top-full z-20 mt-1 w-max min-w-[12rem] -translate-x-1/2 rounded-md border border-white/25 bg-steelnav/95 px-1 py-1 text-white opacity-0 invisible transition duration-300 peer-checked:visible peer-checked:opacity-100 group-hover:visible group-hover:opacity-100 lg:left-full lg:top-0 lg:mt-0 lg:ml-1 lg:translate-x-0{% endif %}">
    {% for item in items %}
        {% set hasSubItems = item.subitems|default %}
        {% if hasSubItems %}
            <li{{ attrs().addClass([item.class|default, 'group relative', item.isActive ? 'active' : null]).set('aria-haspopup', 'true') }}>
                <input{{ attrs()
                    .set('id', 'group-' ~ item.id)
                    .set('type', 'checkbox')
                    .set('checked', 'checked', 'trail' in (item.class|default('')))
                    .set('style', 'display:none')
                    .addClass('peer')
                }}>
                <label{{ attrs().set('for', 'group-' ~ item.id).addClass(isRoot ? 'inline-flex cursor-pointer items-center gap-1 rounded px-3 py-1 text-sm font-headline uppercase tracking-wide hover:bg-white/10' : 'inline-flex cursor-pointer items-center justify-between w-full rounded px-3 py-1 text-xs font-headline uppercase tracking-wide hover:bg-white/10') }}>
                    <span>{{ item.link }}</span>
                </label>
                {{- item.subitems|raw -}}
            </li>
        {% else %}
            {% if item.isActive %}
                <li class="{{ item.class|default }} active">
                    <label class="inline-flex rounded bg-white/15 px-3 py-1 text-sm font-headline uppercase tracking-wide">{{ item.link }}</label>
                </li>
            {% else %}
                <li{{ attrs().addClass(item.class|default) }}>
                    <a{{ attrs()
                        .set('href', item.href ?: './')
                        .set('title', item.pageTitle ?: item.title)
                        .setIfExists('accesskey', item.accesskey|default)
                        .set('tabindex', item.tabindex, item.tabindex|default)
                        .mergeWith(item.target|default)
                        .mergeWith(item.rel|default)
                        .set('aria-haspopup', 'true', item.subitems|default)
                        .addClass(isRoot ? 'inline-flex rounded px-3 py-1 text-sm font-headline uppercase tracking-wide hover:bg-white/10' : 'inline-flex w-full rounded px-3 py-1 text-xs font-headline uppercase tracking-wide hover:bg-white/10')
                    }}>
                        {{ item.link }}
                        {% if item.type == 'redirect' and 'http' in (item.href|default('')) %}
                            <svg class="relative -top-[1px] ml-1 inline-block" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6m-7 1l9-9m-5 0h5v5" />
                            </svg>
                        {% endif %}
                    </a>
                </li>
            {% endif %}
        {% endif %}
    {% endfor %}
</ul>
