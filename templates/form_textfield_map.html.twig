{% extends 'form_row.html.twig' %}

{% block label %}
    {% if this.label %}
        <label for="ctrl_{{ this.id }}"{% if this.class|default %} class="{{ this.class|default }}"{% endif %}>
            {% if this.mandatory|default %}
                <span class="invisible">{{ this.mandatoryField }} </span>{{ this.label|insert_tag_raw }}<span class="mandatory">*</span>
            {% else %}
                <b>{{ this.label|insert_tag_raw }}</b><br>
                {{ this.placeholder|default|insert_tag_raw }}<br>
            {% endif %}
        </label>
    {% endif %}
{% endblock %}

{% block field %}
    {% if hasErrors.invoke() %}
        <p class="error">{{ getErrorAsString.invoke() }}</p>
    {% endif %}

    <input{{ attrs()
        .set('type', 'hidden')
        .set('name', this.name)
        .set('id', "ctrl_#{this.id}")
        .addClass('text')
        .addClass('password', this.hideInput|default)
        .addClass(this.class|default)
        .set('value', this.value|default|insert_tag)
        .mergeWith(getAttributes.invoke())
    }}>

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css">
    <div id="mapid_{{ this.id }}" style="height: 400px; margin-top: 6px;"></div>
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script{{ attrs().setIfExists('nonce', csp_nonce('script-src')) }}>
        (function() {
            var map = L.map('mapid_{{ this.id|e('js') }}').setView([48.950, 9.12], 13);

            L.tileLayer('https://{s}.tile.openstreetmap.de/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
            }).addTo(map);

            var currentMarker = null;
            map.on('click', function(e) {
                var latlng = e.latlng;
                var input = document.getElementById('ctrl_{{ this.id|e('js') }}');

                if (input) {
                    input.value = latlng.lat + ', ' + latlng.lng;
                }

                if (currentMarker) {
                    map.removeLayer(currentMarker);
                }

                currentMarker = L.marker(latlng).addTo(map);
            });
        })();
    </script>
{% endblock %}
